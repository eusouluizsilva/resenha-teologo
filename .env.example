# ─── CLERK (Auth) ─────────────────────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─── CONVEX (Database + Backend) ──────────────────────────────────────────────
# Gerado automaticamente ao rodar: npx convex dev
VITE_CONVEX_URL=https://xxxxxxxxx.convex.cloud

# ─── STRIPE (Pagamentos) ──────────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── RESEND (Email transacional) ──────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@resenhadoteologo.com

# ─── CLOUDFLARE R2 (Storage de arquivos) ──────────────────────────────────────
# Configurado no Convex (Settings → Environment Variables), não no Vercel.
# Account ID: 675e4e9276b5f9bae24216781404dba9
# Bucket: resenha-do-teologo (precisa ser criado em https://dash.cloudflare.com → R2)
# Token: criar em https://dash.cloudflare.com/.../r2/api-tokens com Object R/W escopado pro bucket
R2_ACCOUNT_ID=675e4e9276b5f9bae24216781404dba9
R2_BUCKET=resenha-do-teologo
R2_ENDPOINT=https://675e4e9276b5f9bae24216781404dba9.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
# Opcional, pra servir via custom domain (cdn.resenhadoteologo.com). Se vazio,
# convex/r2.ts gera presigned GET com 7 dias de validade.
R2_PUBLIC_BASE_URL=

# ─── GOOGLE ANALYTICS 4 (opcional) ────────────────────────────────────────────
# https://analytics.google.com → Admin → Property → Data Streams → Web → Measurement ID (formato G-XXXXXXX)
# Sem este valor, o GA4 fica desativado e o site não carrega gtag.js.
# Lembrar de criar 3 custom dimensions no painel GA4: creator_id, course_id, lesson_id.
VITE_GA4_MEASUREMENT_ID=

# ─── GOOGLE ADSENSE (opcional) ────────────────────────────────────────────────
# https://www.google.com/adsense → Site approved → Publisher ID (formato ca-pub-XXXXXXXXXXXXXXXX)
# Sem este valor, AdSlot não renderiza nada e o script da AdSense não é carregado.
# Os ad units (slot IDs) são criados manualmente no painel e referenciados em src/components/AdSlot.tsx.
VITE_ADSENSE_PUBLISHER_ID=

# ─── SENTRY (Monitoramento de erros, opcional) ────────────────────────────────
# https://sentry.io → criar projeto "React" → copiar DSN (https://...@o000000.ingest.us.sentry.io/0000000)
# Sem este valor, o Sentry vira no-op (sem custo, sem requests). Replays só
# disparam em sessões com erro (replaysOnErrorSampleRate=1.0); sessões saudáveis
# não geram replay (replaysSessionSampleRate=0).
VITE_SENTRY_DSN=
# Opcional. Default: 'production' em build, 'development' em dev.
VITE_SENTRY_ENVIRONMENT=
# Opcional. Útil pra rastrear release no Sentry (ex.: git SHA do commit).
VITE_SENTRY_RELEASE=
