# ─── CLERK (Auth) ─────────────────────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─── CONVEX (Database + Backend) ──────────────────────────────────────────────
# Gerado automaticamente ao rodar: npx convex dev
VITE_CONVEX_URL=https://xxxxxxxxx.convex.cloud

# ─── STRIPE (Pagamentos) ──────────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── RESEND (Email transacional) ──────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@resenhadoteologo.com

# ─── CLOUDFLARE R2 (Storage de arquivos) ──────────────────────────────────────
# https://dash.cloudflare.com → R2 → Manage R2 API Tokens
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_R2_ACCESS_KEY_ID=...
CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
CLOUDFLARE_R2_BUCKET_NAME=resenha-do-teologo
VITE_R2_PUBLIC_URL=https://storage.resenhadoteologo.com

# ─── GOOGLE ANALYTICS 4 (opcional) ────────────────────────────────────────────
# https://analytics.google.com → Admin → Property → Data Streams → Web → Measurement ID (formato G-XXXXXXX)
# Sem este valor, o GA4 fica desativado e o site não carrega gtag.js.
# Lembrar de criar 3 custom dimensions no painel GA4: creator_id, course_id, lesson_id.
VITE_GA4_MEASUREMENT_ID=

# ─── GOOGLE ADSENSE (opcional) ────────────────────────────────────────────────
# https://www.google.com/adsense → Site approved → Publisher ID (formato ca-pub-XXXXXXXXXXXXXXXX)
# Sem este valor, AdSlot não renderiza nada e o script da AdSense não é carregado.
# Os ad units (slot IDs) são criados manualmente no painel e referenciados em src/components/AdSlot.tsx.
VITE_ADSENSE_PUBLISHER_ID=
